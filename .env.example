# Orbit App Environment Variables
#
# SETUP INSTRUCTIONS:
# 1. Copy this file and rename it to ".env" (remove the .example extension)
# 2. Fill in the values below
# 3. NEVER commit the .env file to git (it contains secrets)
#
# Run this command to create your .env file:
#   cp .env.example .env

# SendGrid API Key (get from team lead or SendGrid dashboard)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Sender Email (must be verified in SendGrid)
SENDER_EMAIL=theorbitapp.noreply@gmail.com

# Sender Name (appears in email "From" field)
SENDER_NAME=Orbit

# APNs (Apple Push Notifications)
APNS_KEY_PATH=./AuthKey_XXXXXXXX.p8
APNS_KEY_ID=your_apns_key_id_here
APNS_TEAM_ID=your_team_id_here
APNS_BUNDLE_ID=adrian.Orbit
APNS_USE_SANDBOX=true
